+private func fourCharCodeFrom(_ string: String) -> UInt32 {
+    var result: UInt32 = 0
+    for (index, byte) in string.utf8.prefix(4).enumerated() {
+        result |= UInt32(byte) << (8 * (3 - index))
+    }
+    return result
+}
